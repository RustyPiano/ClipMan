# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Dependency directories
node_modules/

# Svelte / Vite build outputs
.svelte-kit/
build/
dist/
dist-ssr/

# Tauri build outputs
src-tauri/target/
src-tauri/gen/

# IDEs and editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# User-specific tool configs (shared project hooks/settings ARE committed)
.claude/*
!.claude/settings.json
!.claude/hooks/
.claude/settings.local.json
.serena/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Misc
*.local

# Code-signing material — NEVER commit (private keys, p12, base64-encoded cert).
# These live in GitHub Actions secrets for release; the local copy is a backup.
ClipMan-signing/
*.p12
*.pem
*_CERTIFICATE.base64.txt

# Locally installed Claude skill copies (like node_modules; skills-lock.json is
# the committed manifest that reproduces them).
.agents/